TRUMPLIN_JWT_SECRET=change_me_super_secret
TRUMPLIN_DATABASE_DSN=postgres://trumplin:trumplin@postgres:5432/trumplin?sslmode=disable
TRUMPLIN_ACCESS_TOKEN_TTL_SECONDS=900
TRUMPLIN_HTTP_PORT=8080

# Yandex Geocoder (HTTP) для офлайн-локаций
YANDEX_GEOCODER_KEY=CHANGE_ME
YANDEX_GEOCODER_BASE_URL=https://geocode-maps.yandex.ru/1.x/

# Yandex Maps JS (фронт) для карты
YANDEX_JAVASCRIPT_API_KEY=CHANGE_ME

# Initial admin account for curator access (curator login).
TRUMPLIN_ADMIN_EMAIL=admin@example.com
TRUMPLIN_ADMIN_PASSWORD=change_me_admin_password

